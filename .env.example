# MeshPi Environment Variables Configuration
# Copy this file to .env and fill in your actual values
#
# This file contains all environment variables used by MeshPi
# Different sections for different use cases

# ─────────────────────────────────────────────────────────────────
# 🐳 DOCKER & DEPLOYMENT
# ─────────────────────────────────────────────────────────────────

# Host service configuration
MESHPI_PORT=7422
MESHPI_BIND=0.0.0.0

# Client configuration
MESHPI_HOST_IP=localhost
MESHPI_HOST_PORT=7422
MESHPI_DEVICE_ID=meshpi-client
MESHPI_DRY_RUN=0
MESHPI_SIMULATE=0
MESHPI_INTEGRATION=0

# ─────────────────────────────────────────────────────────────────
# 🔧 MESHPI CONFIGURATION (MESHPI_CFG_* → config.env)
# ─────────────────────────────────────────────────────────────────
# These variables are automatically converted to config.env format
# Example: MESHPI_CFG_WIFI_SSID=MyNet → WIFI_SSID="MyNet"

# SSH Configuration
MESHPI_CFG_RPI_USER=pi
MESHPI_CFG_RPI_PASSWORD=
MESHPI_CFG_SSH_PUBLIC_KEY=
MESHPI_CFG_SSH_ENABLE=yes
MESHPI_CFG_SSH_PORT=22
MESHPI_CFG_SSH_PASSWORD_AUTH=yes

# WiFi Configuration  
MESHPI_CFG_WIFI_SSID=
MESHPI_CFG_WIFI_PASSWORD=
MESHPI_CFG_WIFI_COUNTRY=PL

# Hostname & System
MESHPI_CFG_RPI_HOSTNAME=meshpi-node
MESHPI_CFG_RPI_TIMEZONE=Europe/Warsaw
MESHPI_CFG_RPI_LOCALE=pl_PL.UTF-8
MESHPI_CFG_RPI_KEYBOARD=pl

# Hardware Interfaces
MESHPI_CFG_ENABLE_I2C=no
MESHPI_CFG_ENABLE_SPI=no
MESHPI_CFG_ENABLE_SERIAL=no
MESHPI_CFG_ENABLE_CAMERA=no

# Network Configuration
MESHPI_CFG_STATIC_IP=
MESHPI_CFG_GATEWAY=
MESHPI_CFG_DNS_SERVERS=8.8.8.8,8.8.4.4

# Optional Scripts
MESHPI_CFG_POST_SCRIPT_URL=

# ─────────────────────────────────────────────────────────────────
# 🤖 LLM AGENT CONFIGURATION
# ─────────────────────────────────────────────────────────────────

# LiteLLM Configuration
LITELLM_MODEL=gpt-4o-mini
LITELLM_API_KEY=
LITELLM_API_BASE=

# Alternative API Keys (automatically used by LiteLLM)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AZURE_OPENAI_API_KEY=
GOOGLE_API_KEY=

# ─────────────────────────────────────────────────────────────────
# 📦 PyPI & PUBLISHING
# ─────────────────────────────────────────────────────────────────

# PyPI tokens for package publishing
PYPI_TOKEN=
TEST_PYPI_TOKEN=

# ─────────────────────────────────────────────────────────────────
# 🧪 TESTING & DEVELOPMENT
# ─────────────────────────────────────────────────────────────────

# Test configuration
TEST_RPI_DEVICES=pi@localhost
TEST_SSH_KEY=~/.ssh/id_rsa
TEST_TIMEOUT=300
TEST_PARALLEL_JOBS=5

# Development settings
PYTHONUNBUFFERED=1
DEBUG=0

# ─────────────────────────────────────────────────────────────────
# 📊 LOGGING & MONITORING
# ─────────────────────────────────────────────────────────────────

# Log levels
LOG_LEVEL=INFO
MESHPI_LOG_LEVEL=INFO

# Monitoring paths
STATUS_FILE=/tmp/meshpi-status.txt
LOG_FILE=/tmp/meshpi-repair.log
NEXT_STEPS_FILE=/tmp/meshpi-next-steps.txt
HELP_FILE=/tmp/meshpi-help.txt

# ─────────────────────────────────────────────────────────────────
# 🔐 SECURITY & CRYPTO
# ─────────────────────────────────────────────────────────────────

# Key paths (auto-generated if not exists)
MESHPI_KEY_PATH=/root/.meshpi
MESHPI_PUBLIC_KEY_FILE=/root/.meshpi/public_key.pem
MESHPI_PRIVATE_KEY_FILE=/root/.meshpi/private_key.pem

# ─────────────────────────────────────────────────────────────────
# 📝 USAGE EXAMPLES
# ─────────────────────────────────────────────────────────────────

# Docker usage:
# docker run -p 7422:7422 \
#   -e MESHPI_CFG_WIFI_SSID="MyNetwork" \
#   -e MESHPI_CFG_WIFI_PASSWORD="MyPassword" \
#   -e MESHPI_CFG_RPI_USER="pi" \
#   -e LITELLM_API_KEY="sk-..." \
#   meshpi

# Local development:
# export MESHPI_PORT=7422
# export LITELLM_MODEL=gpt-4o
# export OPENAI_API_KEY=sk-...
# meshpi host

# Client usage:
# export MESHPI_HOST_IP=192.168.1.100
# export MESHPI_HOST_PORT=7422
# meshpi scan
